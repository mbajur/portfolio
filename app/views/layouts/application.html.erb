<!DOCTYPE html>
<html>
  <head>
    <title>Portfolio</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script type="module" src="https://cdn.jsdelivr.net/npm/@hotwired/turbo@latest/dist/turbo.es2017-esm.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
      @theme {
        --font-mono: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
      }
    </style>

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
  </head>

  <body class="bg-<% @cms_page.fragments.find_by(identifier: 'bg_class')&.content %>">
    <nav class="flex w-full justify-between px-10 font-mono text-sm uppercase fixed top-6 [&_a]:hover:italic">
      <a href="/" class="underline underline-offset-4 decoration-1">Mike Bajur</a>
      <%= active_link_to 'Locations', '/locations', class_active: 'text-rose-500' %>
      <%= active_link_to 'Projects', '/projects', class_active: 'text-rose-500' %>
      <%= active_link_to 'About', '/about', class_active: 'text-rose-500' %>
    </nav>

    <%= yield %>
  </body>
</html>
